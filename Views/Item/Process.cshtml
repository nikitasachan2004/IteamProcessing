@model List<ItemProcessingSystemCore.Models.Item>

@{
    ViewData["Title"] = "Process Relations";
}

<h2 class="mb-3">Process Item — Create Relations</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-warning">
        No items found. <a asp-action="Create">Create an item first</a>.
    </div>
}
else if (Model.Count < 2)
{
    <div class="alert alert-warning">
        You need at least 2 items to create relations. <a asp-action="Create">Add more items</a>.
    </div>
}
else
{
    <p class="text-muted small mb-3">
        Select a parent item and one or more child items to create parent-child relationships.
    </p>

    <form method="post" style="max-width:600px">
        @Html.AntiForgeryToken()

        <div class="mb-4">
            <label for="parentId" class="form-label fw-bold">Parent Item</label>
            <select name="parentId" id="parentId" class="form-select">
                @foreach (var item in Model)
                {
                    <option value="@item.ItemId">@item.Name (ID: @item.ItemId, Weight: @item.Weight)</option>
                }
            </select>
        </div>

        <div class="mb-4">
            <label class="form-label fw-bold">Child Items</label>
            <p class="text-muted small mb-2">Check one or more items to add as children of the parent above.</p>
            <div class="border rounded p-3" style="max-height:240px; overflow-y:auto;">
                @foreach (var item in Model)
                {
                    <div class="form-check mb-1">
                        <input class="form-check-input" type="checkbox"
                               name="childIds" value="@item.ItemId" id="child_@item.ItemId" />
                        <label class="form-check-label" for="child_@item.ItemId">
                            @item.Name (ID: @item.ItemId, Weight: @item.Weight)
                        </label>
                    </div>
                }
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success">Create Relations</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <a asp-action="Tree" class="btn btn-warning">View Tree</a>
        </div>
    </form>
}