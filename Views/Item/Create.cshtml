@model ItemProcessingSystemCore.Models.Item

@{
    ViewData["Title"] = "Add Item";
}

<h2 class="mb-4">Add Item</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        <strong>Please fix the following errors:</strong>
        <ul class="mb-0 mt-1">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(x => x.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form method="post" style="max-width:480px">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label for="Name" class="form-label">Item Name</label>
        <input type="text" id="Name" name="Name" value="@Model?.Name"
               class="form-control" placeholder="Enter item name" maxlength="100" required />
        <div class="form-text">Maximum 100 characters</div>
    </div>

    <div class="mb-3">
        <label for="Weight" class="form-label">Weight</label>
        <input type="number" id="Weight" name="Weight" value="@Model?.Weight"
               class="form-control" step="0.1" min="0.1" max="10000" placeholder="0.1 – 10000" required />
        <div class="form-text">Must be between 0.1 and 10,000</div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Create Item</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}